# API server bind settings.
HOST=0.0.0.0
PORT=8080

# Comma-separated browser origins allowed to call the API.
# Use "*" only for local experiments where every origin should be accepted.
ALLOWED_ORIGINS=http://localhost:8080

# Rust Playground upstream base URL used by the proxy client.
RUST_PLAYGROUND_URL=https://play.rust-lang.org
RUST_PLAYGROUND_TIMEOUT_MS=10000

# Per-client rate-limit settings used by the API proxy.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
