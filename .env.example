# Rust Learning Manual API server bind settings.
# In self-hosted production, keep HOST=0.0.0.0 and publish the service through
# a reverse proxy or platform router.
HOST=0.0.0.0
PORT=8080

# Comma-separated browser origins allowed to call the API. Set this to the
# public origin serving apps/web/dist, for example:
# ALLOWED_ORIGINS=https://rust-manual.example.com
# Use "*" only for disposable local experiments.
ALLOWED_ORIGINS=http://localhost:8080

# Rust Playground upstream base URL used by the proxy client. Override only
# when testing against a compatible internal mirror.
RUST_PLAYGROUND_URL=https://play.rust-lang.org

# Request timeout for calls from the proxy to Rust Playground.
RUST_PLAYGROUND_TIMEOUT_MS=10000

# Maximum submitted Rust source size accepted by POST /run, measured in UTF-8 bytes.
RUN_CODE_MAX_BYTES=100000

# Per-client rate-limit settings used by the API proxy.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
